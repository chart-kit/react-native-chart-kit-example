{
  "expo": {
    "name": "React Native Chart Kit Example",
    "slug": "react-native-chart-kit-example",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.react-native-chart-kit-example"
    },
    "android": {
      "package": "com.anonymous.reactnativechartkitexample"
    },
    "web": {
      "bundler": "metro"
    }
  }
}
